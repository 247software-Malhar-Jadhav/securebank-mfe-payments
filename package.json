{
  "name": "securebank-mfe-payments",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "SecureBank Module Federation REMOTE micro-frontend — owns the Transfer and Beneficiaries screens. Runs standalone on :5172 in dev and is consumed by the shell host at runtime.",
